# 6-5 ad-performance-checker 임계값 설정 (.env 에 추가)
# WARN = 디스코드 경고 / BLOCK(CRITICAL) = @멘션 에스컬레이션 후보

THRESHOLD_ROAS_WARN=2.0
THRESHOLD_ROAS_BLOCK=1.0
THRESHOLD_CPA_WARN=30000
THRESHOLD_CPA_BLOCK=50000
THRESHOLD_CTR_WARN=0.01
THRESHOLD_CTR_BLOCK=0.005
THRESHOLD_DAILY_BUDGET_WARN=1.1
THRESHOLD_DAILY_BUDGET_BLOCK=1.3

# 시뮬레이션 모드 (촬영용) : ROAS WARN 을 10.0 으로 올리면
# 모든 캠페인이 경고 대상이 되어 알림 발송 장면을 강제로 재현할 수 있다.
# THRESHOLD_ROAS_WARN=10.0

# 침묵 원칙 : 위반이 0건이면 디스코드에 아무것도 보내지 않는다 (알림 피로 방지)
# 에스컬레이션 : 동일 위반 3시간 연속 시 @멘션
